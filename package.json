{
  "name": "leadchat",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time B2B lead discovery platform for the Indian market",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @leadchat/api",
    "dev:mobile": "npm run dev -w @leadchat/mobile",
    "build:shared": "npm run build -w @leadchat/shared",
    "build:api": "npm run build -w @leadchat/api",
    "build": "npm run build:shared && npm run build:api",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "db:migrate": "docker exec -i leadchat-postgres psql -U leadchat -d leadchat < infra/db/001_initial.sql"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}

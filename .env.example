# ============================================
# LeadChat - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://leadchat:leadchat_dev@localhost:5433/leadchat

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Firebase ---
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_STORAGE_BUCKET=

# --- Razorpay (Mission 5) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Server ---
PORT=4002
NODE_ENV=development
JWT_SECRET=change_me_in_production

# --- CORS ---
CORS_ORIGIN=http://localhost:8081

# --- GST Validation API — Setu (Mission 4) ---
GST_API_CLIENT_ID=
GST_API_CLIENT_SECRET=
GST_API_URL=
